# Interview-demo preset. Applied by: .\demo.ps1 -Demo   (backs up .env first)
# No secrets in this file — it is committed. Put your real TAVILY_API_KEY in
# .env after applying, only if you plan to demo the Internet Researcher.
# glm-5:cloud was retired by Ollama cloud on 2026-07-15 (410 Gone); 5.2 is its successor.
OLLAMA_MODEL=glm-5.2:cloud
OLLAMA_BASE_URL=http://localhost:11434
TAVILY_API_KEY=your_tavily_api_key_here
# Curated in-repo notes served to the RAG agent via md-mcp.
MD_MCP_FOLDER=C:/code/langgraph_ollama/demo-notes
# Long-lived md-mcp HTTP server (started by demo.ps1). Streamable-http +
# traceparent propagation = one distributed trace across app and md-mcp.
# Comment this out to fall back to per-session stdio Docker spawn.
MD_MCP_URL=http://localhost:8000/mcp
# OTLP collector for traces/metrics/logs (LGTM stack from docker-compose).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
