# Copy to .env and fill in real values. .env is git-ignored and must never be committed.
OLLAMA_MODEL=glm-5:cloud
OLLAMA_BASE_URL=http://localhost:11434
TAVILY_API_KEY=your_tavily_api_key_here
# Optional: point the RAG chatbot at a running md-mcp server (streamable-http)
# to give it markdown knowledge-base tools. Leave unset to disable.
# MD_MCP_URL=http://localhost:8000/mcp
