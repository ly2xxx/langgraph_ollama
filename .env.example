# Copy to .env and fill in real values. .env is git-ignored and must never be committed.
OLLAMA_MODEL=glm-5.2:cloud
OLLAMA_BASE_URL=http://localhost:11434
TAVILY_API_KEY=your_tavily_api_key_here
# Optional: point the RAG chatbot at a local folder containing markdown files.
# This will automatically spawn a local md-mcp server in Docker (stdio transport).
# Leave unset to disable.
# MD_MCP_FOLDER=H:/code/yl/interview-prep/notes/YL-notes/interviews/HarveyNash/City-Facilities-Management
